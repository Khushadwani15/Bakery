<script>
    // Template switcher logic
    const buttons = document.querySelectorAll('.switcher-btn');
    const templates = {
        temp1: document.getElementById('temp1'),
        temp2: document.getElementById('temp2'),
        temp3: document.getElementById('temp3'),
        temp4: document.getElementById('temp4'),
        temp5: document.getElementById('temp5')
    };

    function activateTemplate(templateId) {
        Object.values(templates).forEach(template => {
            template.classList.remove('active-template');
        });
        templates[templateId].classList.add('active-template');
        buttons.forEach(btn => {
            btn.classList.remove('active');
            if (btn.getAttribute('data-template') === templateId) {
                btn.classList.add('active');
            }
        });
    }

    buttons.forEach(btn => {
        btn.addEventListener('click', (e) => {
            const templateId = btn.getAttribute('data-template');
            if (templateId && templates[templateId]) {
                activateTemplate(templateId);
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });
    });
</script>
